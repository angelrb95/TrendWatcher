# Copia este archivo como .env y rellena tus credenciales.
# No compartas este archivo si contiene tokens o contrasenas.

# Seguridad web.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena
SECRET_KEY=pon-aqui-una-clave-larga-aleatoria

# URLs de productos separadas por coma. Tambien puedes anadirlas desde el panel admin.
PRODUCT_URLS=https://www.stradivarius.com/es/trench-basica-corta-l01801586?colorId=010&xs=28&pelement=478280955,https://www.stradivarius.com/es/bolso-hombro-plano-tachas-100-piel-l00537101?colorId=450&xs=28&pelement=479201875

# Intervalo entre ciclos completos de revision.
CHECK_INTERVAL_MINUTES=5

# Base de datos SQLite.
DATABASE_PATH=/data/stradivarius_monitor.db
DATA_DIR=/data
LOG_PATH=/data/app.log

# Telegram Bot API.
# Crea un bot con @BotFather y pega aqui SOLO el token del bot.
TELEGRAM_BOT_TOKEN=
# Pega aqui el chat_id numerico o de canal/grupo donde quieres recibir alertas.
TELEGRAM_CHAT_ID=

# Email SMTP. Para Gmail se recomienda usar una "contrasena de aplicacion".
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
